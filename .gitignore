# --- Compiled Binaries & Executables ---
# Ignores the compiled outputs generated by C++ so they don't clutter GitHub
*.exe
*.out
*.o
*.obj
*.app

# --- Code Editor Settings ---
# Ignores your local VS Code or CLion configuration settings
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# --- Python Temporary Files ---
# Ignores Python bytecode cache if you switch to Python
__pycache__/
*.pyc
*.pyo
*.pyd

# --- System Files ---
# Ignores background OS files
.DS_Store
Thumbs.db
